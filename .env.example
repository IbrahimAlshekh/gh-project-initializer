# GitHub Personal Access Token
# Required scopes: repo, project (read:project + write:project)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The GitHub username or organization that owns the target repository
REPO_OWNER=your-username-or-org

# The name of the target repository (must already exist)
REPO_NAME=your-repo-name

# The GraphQL Node ID of the GitHub Project V2 (NOT the project number from the URL).
# See the README guide at the bottom of import_project.py for how to find this value.
# It looks like: PVT_kwDOBxxxxxxxxxxxxxxx
PROJECT_ID=PVT_kwDOBxxxxxxxxxxxxxxx
